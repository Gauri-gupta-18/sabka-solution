rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /issues/{imageId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && (request.auth.token.role == 'Admin' || request.auth.token.role == 'Super Admin');
    }
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
